# Fallback API base (gdy przełącznik globalny jest niedostępny), bez końcowego slasha
NUXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# API URL providera Leapcell
NUXT_PUBLIC_API_BASE_URL_LEAPCELL=http://127.0.0.1:8000
# API URL providera Northflank
NUXT_PUBLIC_API_BASE_URL_NORTHFLANK=http://127.0.0.1:8000
# Publiczny adres frontendu (SEO / OG URL)
NUXT_PUBLIC_SITE_URL=http://localhost:3000

# Domyślny provider przy pierwszym starcie (gdy storage jest pusty): leapcell | northflank
DEFAULT_BACKEND_PROVIDER=leapcell

# Vercel Blob (globalny zapis przełącznika bez klasycznej bazy):
# BLOB_READ_WRITE_TOKEN=...

# Netlify Blobs działa bez dodatkowych zmiennych po stronie Netlify runtime.
