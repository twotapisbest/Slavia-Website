# Instalacja i skrypty: używaj pnpm (package.json → packageManager).
# shamefully-hoist jest interpretowane przez pnpm; przy wywołaniach przez npm/npx możliwe ostrzeżenia — to normalne.
#
# Build na Windows: więcej heap dla Node (unikanie „wiszących” buildów przy GC / Nitro).
node-options=--max-old-space-size=8192

# pnpm: hoist jak npm, żeby część narzędzi (Vite/Nuxt) widziała zależności transitively.
shamefully-hoist=true
